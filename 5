def make_target_distribution_table(df: pd.DataFrame, target_col: str) -> str:
    """Show every target class and its dataset-level row count."""
    counts = df[target_col].astype(str).value_counts(dropna=False)
    total = int(counts.sum())
    rows = [
        {
            "target_class": class_name,
            "row_count": int(count),
            "row_share": f"{count / total:.1%}" if total else "0.0%",
        }
        for class_name, count in counts.items()
    ]
    return pd.DataFrame(rows).to_html(index=False, classes="table")


