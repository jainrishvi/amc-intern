    }
    .feature-selector-bar { display: flex; align-items: center; gap: 8px; margin: 0 0 8px; }
    .feature-count { margin-right: auto; color: var(--tata-peacock); font-size: 12px; font-weight: 700; }
    .feature-action {
      margin: 0;
      padding: 5px 9px;
